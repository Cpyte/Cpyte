# H Import Example# Demonstrates importing C header files and calling declared functions# Usage: python mainpie.py --jit examples/h_import_example.cpyimport "examples/example_functions.h"struct Person:    str name    int age    float heightpublic make_person(name: str, age: int, height: float) -> Person:    Person p    p.name = name    p.age = age    p.height = height    return ppublic print_person(p: Person):    print(p.age)    print(p.height)public main() -> int:    print(1)    int x = 42    int y = x_squared(x)    print(y)    print(2)    int c = cube(x)    print(c)    print(3)    int a = 10    int b = 20    int mx = max_of(a, b)    print(mx)    print(4)    int mn = min_of(a, b)    print(mn)    print(5)    int clamped = clamp(100, 0, 50)    print(clamped)    print(6)    int is_even = is_even(42)    print(is_even)    print(7)    int is_odd = is_odd(43)    print(is_odd)    print(8)    int fact_h = factorial_h(8)    print(fact_h)    print(9)    int ncr = nCr(10, 3)    print(ncr)    print(10)    int npr = nPr(10, 3)    print(npr)    print(11)    int count = count_set_bits(255)    print(count)    print(12)    int parity = has_even_parity(15)    print(parity)    print(13)    int pow2 = next_power_of_two(37)    print(pow2)    print(14)    int range_sum = sum_range(1, 100)    print(range_sum)    print(15)    Person p = make_person("Alice", 30, 165)    print_person(p)    return 0